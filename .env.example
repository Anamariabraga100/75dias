# Copie para .env (local) ou configure na Vercel — nunca commite .env

# Supabase (app + admin)
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_publica_aqui

# URL pública do app (produção)
VITE_APP_URL=https://seu-app.vercel.app

# Google — popup direto (como Varvos). Mesmo Client ID do Google Cloud.
VITE_GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com

# OAuth server-side (opcional / fallback)
VITE_CUSTOM_GOOGLE_OAUTH=true

# --- Variáveis de SERVIDOR (Vercel, sem prefixo VITE_) ---
# Mesmos valores do Google Cloud + Supabase
APP_URL=https://seu-app.vercel.app
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_publica_aqui
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# Admin — login do painel /admin/login
VITE_ADMIN_EMAIL=admin@seudominio.com
VITE_ADMIN_PASSWORD=sua_senha_admin_aqui
