# Copie para .env (local) ou configure na Vercel — nunca commite .env

# Supabase (app + admin)
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_publica_aqui

# URL pública do app (produção)
VITE_APP_URL=https://seu-app.vercel.app

# Google na Vercel (igual Varvos — só servidor, sem VITE_)
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# Opcional local: popup sem depender da API
# VITE_GOOGLE_CLIENT_ID=mesmo_client_id.apps.googleusercontent.com

# OAuth redirect /api (fallback se popup falhar)
VITE_CUSTOM_GOOGLE_OAUTH=true

# --- Servidor (Vercel) — mesmos valores acima ---
APP_URL=https://seu-app.vercel.app
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_publica_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Stripe (só servidor — nunca VITE_)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_QUARTERLY=price_...
STRIPE_PRICE_PROMO_QUARTERLY=price_...

# Stripe Connect — split de pagamento (opcional, desligado por padrão)
# STRIPE_CONNECT_ENABLED=true
# STRIPE_CONNECT_ACCOUNT_ID=acct_...
# STRIPE_CONNECT_APPLICATION_FEE_PERCENT=10
# STRIPE_CONNECT_ACCOUNT_MONTHLY=acct_...
# STRIPE_CONNECT_ACCOUNT_QUARTERLY=acct_...

# Admin — local: só VITE_ADMIN_EMAIL | produção (Vercel): e-mail + senha
VITE_ADMIN_EMAIL=admin@admin.com
VITE_ADMIN_PASSWORD=sua_senha_admin_aqui

# --- Stripe setup ---
# 1. Rode supabase/migrations/003_stripe.sql no SQL Editor
# 2. Crie 3 Prices recorrentes no Dashboard (BRL):
#    - monthly: R$ 34,90/mês (interval: month, count 1)
#    - quarterly: R$ 59,90 a cada 3 meses (interval: month, count 3)
#    - promo quarterly: R$ 49,90 a cada 3 meses (interval: month, count 3)
# 3. Webhook em produção: https://seu-app.vercel.app/api/stripe/webhook
#    Eventos: checkout.session.completed, invoice.paid, invoice.payment_failed,
#             customer.subscription.updated, customer.subscription.deleted
# 4. API local: npx vercel dev (npm run dev não serve /api/*)
# 5. Webhook local: stripe listen --forward-to localhost:3000/api/stripe/webhook

# --- Supabase Dashboard (Authentication → URL Configuration) ---
# Site URL: https://seu-app.vercel.app  (NÃO deixe localhost:3000 em produção!)
# Redirect URLs:
#   https://seu-app.vercel.app/**
#   http://localhost:5173/**
#   http://localhost:4444/**
#
# Admin: rode 001_admin_schema.sql ANTES do 002_bootstrap_admin.sql
# e desligue "Confirm email" em Authentication → Providers → Email

# Google Cloud → Origens JavaScript autorizadas (popup local + produção):
#   http://localhost:5173
#   http://localhost:4444
#   https://seu-app.vercel.app
